---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import {
	JUEJIN_URL,
	SCAFFOLD_GITHUB_URL,
	SITE_DESCRIPTION,
	SITE_TITLE,
	WORKSPACE_GITHUB_URL,
	ZHIHU_URL,
} from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = allPosts.slice(0, 5);

const projects = [
	{
		name: 'Solo Workspace',
		desc: '独立开发者 CLI：服务器 / 域名 / SSL / 密钥 / 待办一站管理',
		href: WORKSPACE_GITHUB_URL,
	},
	{
		name: 'solo-spring-scaffold',
		desc: 'Spring Boot 3 多模块脚手架，插件化 JWT / Docker / Redis / 测试',
		href: SCAFFOLD_GITHUB_URL,
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "干货·工程化复盘",
				"description": "别人教怎么写，我们教怎么不出事——生产环境事故复盘与工程化实战",
				"url": "https://ganhuo.dev",
				"author": { "@type": "Person", "name": "申延彬" }
			}
		</script>
	</head>
	<body>
		<Header />
		<div class="page">
			<main>
			<section class="hero">
				<h1>别人教<span class="hl">怎么写</span>，我们教<span class="hl">怎么不出事</span></h1>
				<p class="tagline">事故复盘 · 工程化实战 · 生产环境经验</p>
				<p class="intro">
					我是 <strong>申延彬</strong>，Java 后端，一线写过方案也排过障。
					这里沉淀<strong>真实生产事故</strong>与排查思路；业余做开源工具，把重复劳动压成脚手架和 CLI。
				</p>
			</section>

			<section class="entries">
				<a href="/about" class="entry">
					<span>📖</span>
					<span>开篇词</span>
					<span>→</span>
				</a>
				<a href="/blog" class="entry">
					<span>🔍</span>
					<span>事故复盘</span>
					<span>→</span>
				</a>
				<a href="/practice" class="entry">
					<span>🛠️</span>
					<span>工程化实践</span>
					<span>→</span>
				</a>
			</section>

			<section class="block">
				<div class="block-head">
					<h2>最新文章</h2>
					<a href="/blog" class="block-more">全部 {allPosts.length} 篇 →</a>
				</div>
				<div class="latest">
					{latestPosts.length > 0 &&
						latestPosts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-item">
								<span class="post-title">{post.data.title}</span>
								<span class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						))}
					{latestPosts.length === 0 && <p class="empty">文章正在路上……</p>}
				</div>
			</section>

			<section class="block">
				<div class="block-head">
					<h2>开源项目</h2>
					<a href="https://github.com/shenyb" class="block-more" target="_blank" rel="noopener noreferrer">
						GitHub →
					</a>
				</div>
				<div class="projects">
					{projects.map((p) => (
						<a href={p.href} class="project" target="_blank" rel="noopener noreferrer">
							<span class="project-name">{p.name}</span>
							<span class="project-desc">{p.desc}</span>
						</a>
					))}
				</div>
			</section>

			<section class="friend-links">
				<span class="fl-label">其它平台</span>
				<a href={ZHIHU_URL} target="_blank" rel="noopener noreferrer">知乎</a>
				<a href={JUEJIN_URL} target="_blank" rel="noopener noreferrer">掘金</a>
				<span class="fl-label fl-gap">友链</span>
				<a href="https://tech.meituan.com/" target="_blank" rel="noopener noreferrer">美团技术</a>
				<a href="https://coolshell.cn/" target="_blank" rel="noopener noreferrer">酷壳</a>
				<a href="https://www.ruanyifeng.com/blog/" target="_blank" rel="noopener noreferrer">阮一峰</a>
				<a href="https://www.infoq.cn/" target="_blank" rel="noopener noreferrer">InfoQ</a>
			</section>
		</main>
		</div>
		<Footer />
	</body>
</html>

<style>
	main {
		display: flex;
		flex-direction: column;
		gap: 1.4em;
		padding: 2em 1em 3em;
		min-height: calc(100vh - 110px);
	}

	.hero {
		text-align: center;
	}
	.hero h1 {
		font-size: 1.6em;
		line-height: 1.3;
		margin: 0 0 0.25em 0;
		color: rgb(var(--black));
	}
	.hl {
		color: var(--accent);
	}
	.tagline {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0 0 0.9em 0;
		letter-spacing: 0.2em;
	}
	.intro {
		max-width: 36em;
		margin: 0 auto;
		font-size: 0.9em;
		line-height: 1.75;
		color: rgb(var(--gray-dark));
		text-align: left;
	}
	.intro strong {
		color: rgb(var(--black));
	}

	.entries {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 0.7em;
	}
	.entry {
		display: flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.9em 1em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 8px;
		text-decoration: none;
		transition: border-color 0.15s;
	}
	.entry:hover {
		border-color: var(--accent);
	}
	.entry span:nth-child(1) {
		font-size: 1.1em;
	}
	.entry span:nth-child(2) {
		flex: 1;
		font-weight: 600;
		font-size: 0.85em;
		color: rgb(var(--black));
		white-space: nowrap;
	}
	.entry span:nth-child(3) {
		color: var(--accent);
		font-size: 0.9em;
	}

	.block-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1em;
		margin-bottom: 0.5em;
	}
	.block-head h2 {
		margin: 0;
		font-size: 0.95em;
		color: rgb(var(--black));
	}
	.block-more {
		font-size: 0.78em;
		color: var(--accent);
		text-decoration: none;
		flex-shrink: 0;
	}
	.block-more:hover {
		text-decoration: underline;
	}

	.latest {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
	}
	.post-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5em;
		padding: 0.5em 0.6em;
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.15s;
	}
	.post-item:hover {
		background: var(--card-bg);
	}
	.post-title {
		font-size: 0.82em;
		color: rgb(var(--gray-dark));
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.post-item:hover .post-title {
		color: var(--accent);
	}
	.post-date {
		font-size: 0.75em;
		color: rgb(var(--gray));
		flex-shrink: 0;
	}
	.empty {
		text-align: center;
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0;
		padding: 0.5em;
	}

	.projects {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.7em;
	}
	.project {
		display: flex;
		flex-direction: column;
		gap: 0.35em;
		padding: 0.9em 1em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 8px;
		text-decoration: none;
		transition: border-color 0.15s;
	}
	.project:hover {
		border-color: var(--accent);
	}
	.project-name {
		font-size: 0.88em;
		font-weight: 600;
		color: rgb(var(--black));
	}
	.project:hover .project-name {
		color: var(--accent);
	}
	.project-desc {
		font-size: 0.78em;
		line-height: 1.45;
		color: rgb(var(--gray));
	}

	.friend-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6em;
		flex-wrap: wrap;
		padding-top: 0.3em;
	}
	.fl-label {
		font-size: 0.72em;
		color: rgb(var(--gray));
		opacity: 0.5;
	}
	.fl-gap {
		margin-left: 0.4em;
	}
	.friend-links a {
		font-size: 0.72em;
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.friend-links a:hover {
		color: var(--accent);
	}

	@media (max-width: 720px) {
		.hero h1 {
			font-size: 1.3em;
		}
		.tagline {
			letter-spacing: 0.1em;
			font-size: 0.75em;
		}
		.entries {
			grid-template-columns: 1fr;
		}
		.projects {
			grid-template-columns: 1fr;
		}
	}
</style>
