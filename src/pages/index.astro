---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = allPosts.slice(0, 5);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "干货·工程化复盘",
				"description": "别人教怎么写，我们教怎么不出事——生产环境事故复盘与工程化实战",
				"url": "https://ganhuo.dev",
				"author": { "@type": "Person", "name": "申延彬" }
			}
		</script>
	</head>
	<body>
		<Header />
		<div class="page">
			<main>
			<!-- Hero：一行标题 -->
			<section class="hero">
				<h1>别人教<span class="hl">怎么写</span>，我们教<span class="hl">怎么不出事</span></h1>
				<p>事故复盘 · 工程化实战 · 生产环境经验</p>
			</section>

			<!-- 入口卡片：三列横铺 -->
			<section class="entries">
				<a href="/about" class="entry">
					<span>📖</span>
					<span>开篇词</span>
					<span>→</span>
				</a>
				<a href="/blog" class="entry">
					<span>🔍</span>
					<span>事故复盘</span>
					<span>→</span>
				</a>
				<div class="entry entry-disabled">
					<span>🛠️</span>
					<span>工程化实践</span>
					<span class="coming">即将开启</span>
				</div>
			</section>

			<!-- 最新文章 -->
			<section class="latest">
				{latestPosts.length > 0 && (
					<>
						{latestPosts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-item">
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						))}
						{allPosts.length > 5 && (
							<a href="/blog" class="post-more">查看全部 {allPosts.length} 篇 →</a>
						)}
					</>
				)}
				{latestPosts.length === 0 && (
					<p class="empty">文章正在路上……</p>
				)}
			</section>

			<!-- 友情链接 -->
			<section class="friend-links">
				<span class="fl-label">友链</span>
				<a href="https://tech.meituan.com/" target="_blank">美团技术</a>
				<a href="https://coolshell.cn/" target="_blank">酷壳</a>
				<a href="https://www.ruanyifeng.com/blog/" target="_blank">阮一峰</a>
				<a href="https://www.infoq.cn/" target="_blank">InfoQ</a>
				<a href="https://aws.amazon.com/cn/blogs/architecture/" target="_blank">AWS 架构</a>
			</section>
		</main>
		</div>
		<Footer />
	</body>
</html>

<style>
	/* ===== 全局：一屏紧凑 ===== */
	main {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1.2em;
		min-height: calc(100vh - 110px);
		padding: 2em 1em;
	}

	/* ===== Hero ===== */
	.hero {
		text-align: center;
	}
	.hero h1 {
		font-size: 1.6em;
		line-height: 1.3;
		margin: 0 0 0.2em 0;
		color: rgb(var(--black));
	}
	.hl { color: var(--accent); }
	.hero p {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0;
		letter-spacing: 0.25em;
	}

	/* ===== 入口卡片：三列横铺 ===== */
	.entries {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 0.7em;
	}
	.entry {
		display: flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.9em 1em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 8px;
		text-decoration: none;
		transition: border-color 0.15s;
	}
	.entry:hover {
		border-color: var(--accent);
	}
	.entry span:nth-child(1) { font-size: 1.1em; }
	.entry span:nth-child(2) {
		flex: 1;
		font-weight: 600;
		font-size: 0.85em;
		color: rgb(var(--black));
		white-space: nowrap;
	}
	.entry span:nth-child(3) {
		color: var(--accent);
		font-size: 0.9em;
	}
	.entry-disabled {
		opacity: 0.55;
		cursor: default;
	}
	.entry-disabled:hover {
		border-color: var(--border);
	}
	.entry-disabled .coming {
		font-size: 0.7em;
		color: rgb(var(--gray));
		white-space: nowrap;
	}

	/* ===== 最新文章 ===== */
	.latest {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
	}
	.post-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5em;
		padding: 0.5em 0.6em;
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.15s;
	}
	.post-item:hover {
		background: var(--card-bg);
	}
	.post-title {
		font-size: 0.82em;
		color: rgb(var(--gray-dark));
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.post-item:hover .post-title {
		color: var(--accent);
	}
	.post-date {
		font-size: 0.75em;
		color: rgb(var(--gray));
		flex-shrink: 0;
	}
	.post-more {
		display: block;
		text-align: center;
		font-size: 0.82em;
		padding: 0.4em;
		color: var(--accent);
		text-decoration: none;
	}
	.post-more:hover {
		text-decoration: underline;
	}
	.empty {
		text-align: center;
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0;
		padding: 0.5em;
	}

	/* ===== 友链 ===== */
	.friend-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6em;
		flex-wrap: wrap;
	}
	.fl-label {
		font-size: 0.72em;
		color: rgb(var(--gray));
		opacity: 0.5;
	}
	.friend-links a {
		font-size: 0.72em;
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.friend-links a:hover {
		color: var(--accent);
	}

	/* ===== 响应式 ===== */
	@media (max-width: 720px) {
		.hero h1 { font-size: 1.3em; }
		.hero p { letter-spacing: 0.1em; font-size: 0.75em; }
		.entry-row { grid-template-columns: 1fr; }
	}
</style>
