---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const posts = allPosts.filter(p => p.data.tags && p.data.tags.length > 0);
const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))].sort();
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`事故复盘 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="page layout">
			<!-- 左侧：文章列表 -->
			<main>
				<div class="list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="item">
							<div class="item-body">
								<h2 class="item-title">{post.data.title}</h2>
								<p class="item-desc">{post.data.description}</p>
								<div class="item-meta">
									<time class="item-date"><FormattedDate date={post.data.pubDate} /></time>
									{post.data.tags && (
										<div class="item-tags">
											{post.data.tags.slice(0, 4).map((tag) => (
												<span class="tag">{tag}</span>
											))}
										</div>
									)}
								</div>
							</div>
							<span class="item-arrow">→</span>
						</a>
					))}
				</div>

				{posts.length === 0 && (
					<p class="empty">文章正在路上……</p>
				)}
			</main>

			<!-- 右侧：目录 -->
			<aside class="sidebar">
				<h3 class="sidebar-title">📋 分类</h3>
				<nav class="sidebar-nav">
					<a href="/blog" class="sidebar-item active">
						<span class="sidebar-item-title">全部文章</span>
						<span class="sidebar-count">{posts.length}</span>
					</a>
					{allTags.map((tag) => (
						<div class="sidebar-item sidebar-tag">
							<span class="sidebar-item-title">{tag}</span>
						</div>
					))}
				</nav>
			</aside>
		</div>
		<Footer />
	</body>
</html>

<style>
	.layout {
		display: flex;
		gap: 2em;
		max-width: 1020px;
		margin: 0 auto;
		padding: 2em 1em;
		min-height: calc(100vh - 110px);
	}

	/* 左侧主内容 */
	main {
		flex: 1;
		min-width: 0;
		padding: 0;
	}

	.list {
		display: flex;
		flex-direction: column;
		gap: 0.6em;
	}

	.item {
		display: flex;
		align-items: center;
		gap: 0.8em;
		padding: 1em 1.2em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 10px;
		text-decoration: none;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.item:hover {
		border-color: var(--accent);
		box-shadow: 0 0 0 1px var(--accent);
	}

	.item-body {
		flex: 1;
		min-width: 0;
	}
	.item-title {
		font-size: 1em;
		font-weight: 600;
		margin: 0 0 0.3em 0;
		color: rgb(var(--black));
		line-height: 1.4;
	}
	.item:hover .item-title {
		color: var(--accent);
	}
	.item-desc {
		font-size: 0.82em;
		color: rgb(var(--gray));
		margin: 0 0 0.4em 0;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.item-meta {
		display: flex;
		align-items: center;
		gap: 0.6em;
		flex-wrap: wrap;
	}
	.item-date {
		font-size: 0.75em;
		color: rgb(var(--gray));
		flex-shrink: 0;
	}
	.item-tags {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
	}
	.tag {
		font-size: 0.7em;
		padding: 0.15em 0.5em;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: rgb(var(--gray));
	}
	.item-arrow {
		color: var(--accent);
		font-size: 1.1em;
		flex-shrink: 0;
		opacity: 0.4;
	}
	.item:hover .item-arrow {
		opacity: 1;
	}

	.empty {
		text-align: center;
		font-size: 0.9em;
		color: rgb(var(--gray));
		padding: 2em 0;
	}

	/* 右侧边栏 */
	.sidebar-title {
	 font-size: 0.85em;
	 color: rgb(var(--gray));
	 margin: 0 0 0.8em 0;
	 font-weight: 600;
	}
	.sidebar-nav {
	 display: flex;
	 flex-direction: column;
	 gap: 0.2em;
	}
	.sidebar-item {
	 display: flex;
	 align-items: center;
	 justify-content: space-between;
	 gap: 0.5em;
	 padding: 0.45em 0.6em;
	 border-radius: 6px;
	 text-decoration: none;
	 transition: background 0.15s;
	 border-left: 2px solid transparent;
	}
	.sidebar-item:hover {
	 background: var(--card-bg);
	}
	.sidebar-item.active {
	 background: var(--card-bg);
	 border-left-color: var(--accent);
	}
	.sidebar-item-title {
	 font-size: 0.78em;
	 color: rgb(var(--gray-dark));
	 line-height: 1.3;
	}
	.sidebar-item.active .sidebar-item-title {
	 color: var(--accent);
	 font-weight: 600;
	}
	.sidebar-count {
	 font-size: 0.7em;
	 color: rgb(var(--gray));
	}
	.sidebar-tag {
	 cursor: default;
	}
	.sidebar-tag .sidebar-item-title {
	 color: rgb(var(--gray));
	 font-size: 0.75em;
	}

	/* 响应式：窄屏时侧边栏变横向 */
	@media (max-width: 860px) {
	 .sidebar-nav {
	  flex-direction: row;
	  flex-wrap: wrap;
	  gap: 0.3em;
	 }
	 .sidebar-item {
	  border-left: none;
	  border-bottom: 2px solid transparent;
	 }
	 .sidebar-item.active {
	  border-bottom-color: var(--accent);
	  border-left-color: transparent;
	 }
	}
</style>
