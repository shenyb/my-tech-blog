---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

import { SCAFFOLD_GITHUB_URL, ZHIHU_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	sidebarPosts?: CollectionEntry<'blog'>[];
};

const { title, description, pubDate, tags, sidebarPosts = [] } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="zh-CN">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			pubDate={pubDate}
			tags={tags}
		/>
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'BlogPosting',
			headline: title,
			description,
			datePublished: pubDate.toISOString(),
			author: { '@type': 'Person', name: '申延彬' },
			publisher: { '@type': 'Organization', name: '干货·工程化复盘' },
			mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.href },
			keywords: tags?.join(', '),
		})} />
	</head>

	<body>
		<Header />
		<div class="page layout">
			<!-- 左侧主内容 -->
			<main>
				<article class="article">
					<header class="header">
						<h1 class="title">{title}</h1>
						<div class="meta">
							<time class="date"><FormattedDate date={pubDate} /></time>
							{tags && tags.length > 0 && (
								<div class="tags">
									{tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							)}
						</div>
					</header>

					<div class="content">
						<slot />
					</div>

					<footer class="article-footer">
						<hr />
						<p>
							👉 <strong>GitHub 地址</strong>：
							<a href={SCAFFOLD_GITHUB_URL} target="_blank" rel="noopener noreferrer">
								{SCAFFOLD_GITHUB_URL}
							</a>
						</p>
						<p>👉 <strong>给个 Star</strong>，是对开源作者最好的鼓励</p>
						<p>
							👉 <strong>知乎</strong>
							<a href={ZHIHU_URL} target="_blank" rel="noopener noreferrer">{ZHIHU_URL}</a>
						</p>
					</footer>
				</article>
			</main>

			<!-- 右侧边栏：文章目录 -->
			<aside class="sidebar">
				<h3 class="sidebar-title">📋 目录</h3>
				<nav class="sidebar-nav">
					{sidebarPosts.map((p) => {
						const isActive = p.id === Astro.url.pathname.replace('/blog/', '').replace('/', '');
						return (
							<a href={`/blog/${p.id}/`} class={`sidebar-item ${isActive ? 'active' : ''}`}>
								<span class="sidebar-item-title">{p.data.title}</span>
								<time class="sidebar-item-date"><FormattedDate date={p.data.date || p.data.pubDate} /></time>
							</a>
						);
					})}
				</nav>
			</aside>
		</div>
		<Footer />
	</body>
</html>

<style>
	/* ===== 右侧边栏目录 ===== */
	.sidebar-title {
	  font-size: 0.85em;
	  color: rgb(var(--gray));
	  margin: 0 0 0.8em 0;
	  font-weight: 600;
	  position: sticky;
	  top: 0;
	  background: var(--bg);
	  padding-bottom: 0.5em;
	  z-index: 1;
	 }
	.sidebar-nav {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
	}
	.sidebar-item {
		display: flex;
		flex-direction: column;
		gap: 0.1em;
		padding: 0.45em 0.6em;
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.15s;
		border-left: 2px solid transparent;
	}
	.sidebar-item:hover {
		background: var(--card-bg);
	}
	.sidebar-item.active {
		background: var(--card-bg);
		border-left-color: var(--accent);
	}
	.sidebar-item-title {
	  font-size: 0.78em;
	  color: rgb(var(--gray-dark));
	  line-height: 1.3;
	  display: -webkit-box;
	  -webkit-line-clamp: 2;
	  -webkit-box-orient: vertical;
	  overflow: hidden;
	 }
	 .sidebar-item:hover .sidebar-item-title {
	  -webkit-line-clamp: unset;
	  display: block;
	  overflow: visible;
	 }
	.sidebar-item.active .sidebar-item-title {
		color: var(--accent);
		font-weight: 600;
	}
	.sidebar-item-date {
		font-size: 0.68em;
		color: rgb(var(--gray));
	}

	/* ===== 文章头部 ===== */
	.header {
		margin-bottom: 2em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid var(--border);
	}
	.title {
		font-size: 1.8em;
		line-height: 1.3;
		margin: 0 0 0.6em 0;
		color: rgb(var(--black));
	}
	.meta {
		display: flex;
		align-items: center;
		gap: 0.8em;
		flex-wrap: wrap;
	}
	.date {
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.tags {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
	}
	.tag {
		font-size: 0.75em;
		padding: 0.15em 0.5em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: rgb(var(--gray));
	}

	/* ===== 文章正文 ===== */
	.content {
		font-size: 1em;
		line-height: 1.8;
		color: rgb(var(--gray-dark));
	}

	.content :global(h1) {
		font-size: 1.6em;
		margin: 1.5em 0 0.5em;
		color: rgb(var(--black));
	}
	.content :global(h2) {
		font-size: 1.3em;
		margin: 1.8em 0 0.5em;
		color: rgb(var(--black));
		border-bottom: 1px solid var(--border);
		padding-bottom: 0.3em;
	}
	.content :global(h3) {
		font-size: 1.1em;
		margin: 1.5em 0 0.4em;
		color: rgb(var(--black));
	}
	.content :global(p) {
		margin: 0 0 1em 0;
		font-size: 1em;
		line-height: 1.8;
		color: rgb(var(--gray-dark));
	}
	.content :global(strong) {
		color: rgb(var(--black));
	}
	.content :global(blockquote) {
		margin: 1em 0;
		padding: 0.5em 1em;
		border-left: 3px solid var(--accent);
		background: var(--card-bg);
		border-radius: 0 6px 6px 0;
	}
	.content :global(blockquote p) {
		margin: 0.3em 0;
		font-size: 0.95em;
		color: rgb(var(--gray));
	}
	.content :global(ul),
	.content :global(ol) {
		padding-left: 1.2em;
		margin: 0 0 1em 0;
	}
	.content :global(li) {
		margin-bottom: 0.3em;
		line-height: 1.7;
		color: rgb(var(--gray-dark));
	}
	.content :global(code) {
		font-size: 0.88em;
		padding: 0.15em 0.4em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: rgb(var(--gray-dark));
	}
	.content :global(pre) {
		margin: 1em 0;
		padding: 1em;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow-x: auto;
		font-size: 0.85em;
		line-height: 1.5;
	}
	.content :global(pre code) {
		all: unset;
		display: block;
		color: rgb(var(--gray-dark));
	}
	.content :global(img) {
		display: block;
		max-width: 100%;
		margin: 1.5em auto;
		border-radius: 8px;
		border: 1px solid var(--border);
	}
	.content :global(table) {
		width: 100%;
		margin: 1em 0;
		border-collapse: collapse;
		font-size: 0.9em;
	}
	.content :global(th),
	.content :global(td) {
		padding: 0.5em 0.8em;
		border: 1px solid var(--border);
		text-align: left;
	}
	.content :global(th) {
		background: var(--card-bg);
		color: rgb(var(--black));
		font-weight: 600;
	}
	.content :global(td) {
		color: rgb(var(--gray-dark));
	}
	.content :global(hr) {
		margin: 2em 0;
		border: none;
		border-top: 1px solid var(--border);
	}
	.content :global(a) {
		color: var(--accent);
		text-decoration: none;
	}
	.content :global(a:hover) {
		text-decoration: underline;
	}
	.content :global(input[type="checkbox"]) {
		margin-right: 0.4em;
	}
	.content :global(pre code) {
		background: none;
		border: none;
		padding: 0;
	}
	.content :global(blockquote code) {
		background: var(--bg);
	}

	.article-footer {
		margin-top: 2.5em;
		padding-top: 0.5em;
	}
	.article-footer hr {
		margin: 0 0 1.5em 0;
		border: none;
		border-top: 1px solid var(--border);
	}
	.article-footer p {
		margin: 0 0 0.6em 0;
		font-size: 0.95em;
		color: rgb(var(--gray-dark));
	}
	.article-footer a {
		color: var(--accent);
		text-decoration: none;
		word-break: break-all;
	}
	.article-footer a:hover {
		text-decoration: underline;
	}

	/* ===== 响应式 ===== */
	@media (max-width: 860px) {
		.layout {
			flex-direction: column;
			padding: 1em;
		}
		.sidebar {
			width: 100%;
			position: static;
			max-height: none;
			margin-bottom: 1em;
		}
		.sidebar-nav {
			flex-direction: row;
			overflow-x: auto;
			gap: 0.3em;
			padding-bottom: 0.5em;
		}
		.sidebar-item {
			flex-shrink: 0;
			width: 180px;
			border-left: none;
			border-bottom: 2px solid transparent;
		}
		.sidebar-item.active {
			border-bottom-color: var(--accent);
			border-left-color: transparent;
		}
		.title {
			font-size: 1.4em;
		}
	}
</style>
